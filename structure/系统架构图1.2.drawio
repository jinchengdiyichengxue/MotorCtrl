<mxfile host="Electron">
  <diagram name="第 1 页" id="Jr3pzw_VwKtSWVEjvN0x">
    <mxGraphModel dx="2372" dy="1406" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="827" pageHeight="1169" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <UserObject label="" mermaidData="{&#xa;  &quot;data&quot;: &quot;graph LR\n    %% 样式定义\n    classDef power fill:#f9d0c4,stroke:#333,stroke-width:2px;\n    classDef mcu fill:#d4e157,stroke:#333,stroke-width:2px,stroke-dasharray: 5 5;\n    classDef drive fill:#b3e5fc,stroke:#333,stroke-width:2px;\n    classDef sensor fill:#c8e6c9,stroke:#333,stroke-width:2px;\n    classDef debug fill:#fff9c4,stroke:#333,stroke-width:2px;\n\n    %% 1. 电源转换系统\n    subgraph 电源转换系统\n        direction TB\n        VIN[12V 直流电源输入] --&gt; AntiRev[防反接电路 PMOS方案]\n        AntiRev --&gt; DCDC[DCDC Buck降压 12V转5V]\n        DCDC --&gt; LDO[LDO线性稳压 5V转3.3V]\n    end\n\n    %% 2. 主控大脑区\n    subgraph 主控大脑与解耦区\n        direction TB\n        MCU[STM32G473CBT6 最小系统\\n备注：所有引脚全部引出以备替换]\n    end\n\n    %% 3. 电机驱动执行模块\n    subgraph 电机驱动执行模块\n        direction TB\n        GateDriver[栅极驱动电路\\n含自举设计_由老大设计] --&gt; Inverter[三相逆变桥\\n6个 NMOS 搭建]\n        Inverter --&gt; Motor(((电 机)))\n    end\n\n    %% 4. 闭环反馈模块\n    subgraph 闭环反馈模块\n        direction TB\n        Encoder[MT6701 绝对式编码器]\n        CurrentSample[电流采样电路\\n两电阻在线采样方案]\n        Gyro[姿态传感器 陀螺仪\\n单独画最小PCB板验证]\n    end\n\n    %% 5. 调试与人机交互模块\n    subgraph 调试与人机交互模块\n        direction TB\n        STLINK[ST-Link 烧录接口\\n靠近MCU布局]\n        UART[串口通信调试接口 UART\\n连接上位机]\n        POT[旋转电位器调速接口\\nADC读取设定速度]\n        TEST_PIN[专用硬件测试端口\\n示波器测中断微秒级执行时间]\n        LED1((上电指示灯))\n        LED2((故障提示灯))\n        LED3((3颗备用测试 LED\\n观察程序防死机))\n    end\n\n    %% 核心跨模块连线 (优化布线路径)\n    LDO --&gt;|3.3V 供电| MCU\n    DCDC -.-&gt;|动力供电| GateDriver\n\n    MCU --&gt;|高级定时器 6路PWM| GateDriver\n\n    Motor -.-&gt;|转子物理位置| Encoder\n    Inverter -.-&gt;|相电流采集| CurrentSample\n\n    Encoder &lt;--&gt;|SPI 通信协议| MCU\n    CurrentSample --&gt;|预留2个调试接口| MCU\n    Gyro &lt;--&gt;|数字通信协议| MCU\n\n    STLINK -.-&gt; MCU\n    UART &lt;--&gt; MCU\n    POT --&gt; MCU\n    TEST_PIN -.-&gt; MCU\n\n    LDO --&gt; LED1\n    MCU --&gt; LED2\n    MCU --&gt; LED3\n\n    %% 应用样式\n    class 电源转换系统 power\n    class 主控大脑与解耦区 mcu\n    class 电机驱动执行模块 drive\n    class 闭环反馈模块 sensor\n    class 调试与人机交互模块 debug&quot;,&#xa;  &quot;config&quot;: null&#xa;}" id="GBfkf_dEptBnS5mvpePR-146">
          <mxCell connectable="0" parent="1" style="group;transparentBounds=1;editIcon=1;lockedGroup=0;groupPadding=10;" vertex="1">
            <mxGeometry height="1540" width="3551" as="geometry" />
          </mxCell>
        </UserObject>
